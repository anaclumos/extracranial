{
  "name": "cho.sh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build:assets": "bun run scripts/build-static-assets.ts",
    "build:assets:fast": "bun run scripts/build-static-assets.ts --skip-og",
    "build:vite": "bun --bun vite build",
    "build": "bun run build:assets && bun run build:vite",
    "preview": "bun --bun vite preview",
    "lint": "bun x ultracite check",
    "format": "bun x ultracite fix",
    "assign-hex": "bun run scripts/assign-hex-slugs.ts",
    "sync:last-modified": "bun run scripts/sync-last-modified.ts",
    "type-check": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
