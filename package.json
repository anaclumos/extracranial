{
	"name": "cho.sh",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "vp dev",
		"build:assets": "tsx scripts/build-static-assets.ts",
		"build:assets:fast": "tsx scripts/build-static-assets.ts --skip-og",
		"build:vite": "vp build",
		"build": "pnpm run build:assets && pnpm run build:vite",
		"preview": "vp preview",
		"lint": "vp lint",
		"format": "vp fmt . --write",
		"assign-hex": "tsx scripts/assign-hex-slugs.ts",
		"sync:last-modified": "tsx scripts/sync-last-modified.ts",
		"type-check": "tsc --noEmit",
		"check": "pnpm run type-check && pnpm run lint",
		"fix": "vp lint --fix"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@hugeicons/core-free-icons": "^4.0.0",
		"@hugeicons/react": "^1.1.6",
		"@resvg/resvg-js": "^2.6.2",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@streamdown/cjk": "^1.0.2",
		"@streamdown/math": "^1.0.2",
		"@tanstack/react-router": "^1.167.4",
		"@tanstack/react-start": "^1.166.15",
		"@tanstack/start-static-server-functions": "^1.166.14",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cobe": "^0.6.5",
		"eiab": "^0.4.2",
		"gray-matter": "^4.0.3",
		"motion": "^12.38.0",
		"motion-plus": "^1.5.1",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"satori": "^0.25.0",
		"shiki": "^4.0.2",
		"streamdown": "^2.4.0",
		"tailwind-merge": "^3.4.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.5",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@rolldown/plugin-babel": "0.2.1",
		"@tailwindcss/vite": "^4",
		"@types/node": "^25.5.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "1.0.0",
		"lefthook": "^2.1.4",
		"nitro": "^3.0.260311-beta",
		"tailwindcss": "^4",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-plus": "0.1.12"
	}
