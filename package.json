    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/math": "^1.0.2",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/start-static-server-functions": "^1.166.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cobe": "^0.6.5",
    "eiab": "^0.4.2",
    "gray-matter": "^4.0.3",
    "motion": "^12.38.0",
    "motion-plus": "^1.5.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "satori": "^0.25.0",
    "shiki": "^4.0.2",
    "streamdown": "^2.4.0",
